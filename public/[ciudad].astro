---
import ciudades from "../data/ciudades.json";
import anuncios from "../data/anuncios.json";

export function getStaticPaths() {
  return ciudades.map((ciudad) => ({
    params: {
      ciudad: ciudad.slug
    },
    props: {
      ciudad
    }
  }));
}

const { ciudad } = Astro.props;

const anunciosCiudad = anuncios.filter(
  (anuncio) => anuncio.ciudad === ciudad.slug
);

const title =
  ciudad.titulo || `Publicidad y negocios en ${ciudad.nombre}`;

const description =
  ciudad.descripcion || `Encontrá negocios y servicios en ${ciudad.nombre}.`;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{title}</title>
  <meta name="description" content={description} />
</head>

<body>
  <header>
    <a href="/">← Volver</a>
    <h1>{title}</h1>
    <p>{description}</p>
  </header>

  <main>
    <section class="banner">
      <h2>Espacio publicitario disponible</h2>
      <p>Tu negocio puede aparecer destacado en {ciudad.nombre}.</p>
    </section>

    <section>
      <h2>Negocios destacados en {ciudad.nombre}</h2>

      {anunciosCiudad.length > 0 ? (
        <div class="grid">
          {anunciosCiudad.map((anuncio) => (
            <article class={anuncio.destacado ? "card destacado" : "card"}>
              {anuncio.destacado && <span>Destacado</span>}

              <h3>{anuncio.titulo}</h3>
              <p><strong>{anuncio.rubro}</strong></p>
              <p>{anuncio.descripcion}</p>

              {anuncio.telefono && (
                <a href={`https://wa.me/54${anuncio.telefono}`} target="_blank">
                  Contactar por WhatsApp
                </a>
              )}
            </article>
          ))}
        </div>
      ) : (
        <div class="vacio">
          <p>No hay anuncios cargados todavía.</p>
        </div>
      )}
    </section>
  </main>
</body>
</html>

<style>
  body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: #f8fafc;
    color: #111827;
  }

  header {
    background: #0f172a;
    color: white;
    padding: 40px 20px;
  }

  header a {
    color: #38bdf8;
    font-weight: bold;
    text-decoration: none;
  }

  main {
    max-width: 1100px;
    margin: auto;
    padding: 30px 20px;
  }

  .banner {
    background: #fde68a;
    color: #78350f;
    padding: 24px;
    border-radius: 14px;
    margin-bottom: 30px;
    text-align: center;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
  }

  .card {
    background: white;
    padding: 22px;
    border-radius: 14px;
    box-shadow: 0 8px 20px rgba(0,0,0,.08);
  }

  .destacado {
    border: 2px solid #f59e0b;
  }

  .card span {
    display: inline-block;
    background: #f59e0b;
    color: white;
    padding: 5px 10px;
    border-radius: 999px;
    font-size: .8rem;
    font-weight: bold;
    margin-bottom: 10px;
  }

  .card a {
    display: inline-block;
    margin-top: 10px;
    color: #16a34a;
    font-weight: bold;
  }

  .vacio {
    background: white;
    padding: 24px;
    border-radius: 14px;
  }
</style>