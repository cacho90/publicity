---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Inicio">
  <section>
    <h2 class="text-2xl font-semibold mb-6 text-outline">Ciudades disponibles</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
      <a href="/ciudades/corrientes" class="bg-white bg-opacity-90 text-black shadow rounded-lg p-6 hover:shadow-lg transition">Corrientes</a>
      <a href="/ciudades/resistencia" class="bg-white bg-opacity-90 text-black shadow rounded-lg p-6 hover:shadow-lg transition">Resistencia</a>
      <a href="/ciudades/chaco" class="bg-white bg-opacity-90 text-black shadow rounded-lg p-6 hover:shadow-lg transition">Chaco</a>
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold mb-6 text-outline">Restaurantes destacados</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white bg-opacity-90 text-black shadow rounded-lg p-6">
        <h3 class="text-lg font-bold text-outline">La Parrilla Corrientes</h3>
        <p class="text-outline">Carnes premium y ambiente familiar.</p>
      </div>
      <div class="bg-white bg-opacity-90 text-black shadow rounded-lg p-6">
        <h3 class="text-lg font-bold text-outline">Sabores del Chaco</h3>
        <p class="text-outline">Comida regional con ingredientes frescos.</p>
      </div>
      <div class="bg-white bg-opacity-90 text-black shadow rounded-lg p-6">
        <h3 class="text-lg font-bold text-outline">Resistencia Gourmet</h3>
        <p class="text-outline">Alta cocina en un entorno elegante.</p>
      </div>
    </div>
  </section>
</BaseLayout>
