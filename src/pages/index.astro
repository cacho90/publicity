---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Inicio">
  <!-- Hero con imagen principal -->
  <section class="relative bg-gray-900 text-white">
    <img src="/images/restaurante.jpg" alt="Banner restaurante" class="w-full h-96 object-cover opacity-70" />
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
      <h1 class="text-4xl font-bold">AnunciaLocal</h1>
      <p class="mt-4 text-lg">Descubre restaurantes confiables en tu ciudad</p>
      <a href="#ciudades" class="mt-6 bg-blue-600 px-6 py-3 rounded-lg hover:bg-blue-700">Explorar ciudades</a>
    </div>
  </section>

  <!-- Ciudades disponibles -->
  <section id="ciudades" class="mt-12">
    <h2 class="text-2xl font-semibold mb-6">Ciudades disponibles</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
      <a href="/ciudades/corrientes" class="bg-white shadow rounded-lg p-6 hover:shadow-lg transition">Corrientes</a>
      <a href="/ciudades/resistencia" class="bg-white shadow rounded-lg p-6 hover:shadow-lg transition">Resistencia</a>
      <a href="/ciudades/chaco" class="bg-white shadow rounded-lg p-6 hover:shadow-lg transition">Chaco</a>
    </div>
  </section>

  <!-- Restaurantes destacados -->
  <section class="mt-12">
    <h2 class="text-2xl font-semibold mb-6">Restaurantes destacados</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <img src="/images/restaurante.jpg" alt="Restaurante destacado" class="w-full h-40 object-cover" />
        <div class="p-4">
          <h3 class="text-lg font-bold">La Parrilla Corrientes</h3>
          <p class="text-gray-600">Carnes premium y ambiente familiar.</p>
          <button class="mt-3 bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Reservar</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
