---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Inicio">
  <section>
    <h2 class="text-2xl font-semibold mb-4">Ciudades disponibles</h2>
    <ul class="grid grid-cols-2 gap-4">
      <li><a href="/ciudades/corrientes" class="block bg-white shadow rounded p-4">Corrientes</a></li>
      <li><a href="/ciudades/resistencia" class="block bg-white shadow rounded p-4">Resistencia</a></li>
      <li><a href="/ciudades/chaco" class="block bg-white shadow rounded p-4">Chaco</a></li>
    </ul>
  </section>

  <section class="mt-10">
    <h2 class="text-2xl font-semibold mb-4">Restaurantes destacados</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white shadow rounded-lg p-6">
        <h3 class="text-lg font-bold">La Parrilla Corrientes</h3>
        <p class="text-gray-600">Carnes premium y ambiente familiar.</p>
      </div>
      <div class="bg-white shadow rounded-lg p-6">
        <h3 class="text-lg font-bold">Sabores del Chaco</h3>
        <p class="text-gray-600">Comida regional con ingredientes frescos.</p>
      </div>
      <div class="bg-white shadow rounded-lg p-6">
        <h3 class="text-lg font-bold">Resistencia Gourmet</h3>
        <p class="text-gray-600">Alta cocina en un entorno elegante.</p>
      </div>
    </div>
  </section>
</BaseLayout>
