---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
    <style>
      .text-outline {
        color: white; /* color principal */
        -webkit-text-stroke: 1px black; /* contorno negro */
        text-shadow: 2px 2px 4px rgba(0,0,0,0.7); /* sombra para más contraste */
      }
    </style>
  </head>
  <body class="bg-fixed bg-cover bg-center" 
        style="background-image: url('https://copilot.microsoft.com/th/id/BCO.9e6bbb61-2d31-4486-86ff-a64e8d3a8072.png');">
    <div class="bg-black bg-opacity-50 min-h-screen">
      <header class="py-6 text-center">
        <h1 class="text-4xl font-bold text-outline">AnunciaLocal</h1>
        <p class="text-lg text-outline">Negocios y servicios por ciudad</p>
      </header>

      <main class="max-w-7xl mx-auto py-10 px-4">
        <slot />
      </main>

      <footer class="bg-black bg-opacity-70 py-4 mt-10 text-center text-outline">
        © 2026 AnunciaLocal - Todos los derechos reservados
      </footer>
    </div>
  </body>
</html>
