---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body class="bg-fixed bg-cover bg-center text-white" 
        style="background-image: url('https://copilot.microsoft.com/th/id/BCO.9e6bbb61-2d31-4486-86ff-a64e8d3a8072.png');">
    <!-- Overlay para contraste -->
    <div class="bg-black bg-opacity-60 min-h-screen">
      <header class="py-6 text-center">
        <h1 class="text-4xl font-bold drop-shadow-lg">AnunciaLocal</h1>
        <p class="text-gray-200">Negocios y servicios por ciudad</p>
      </header>

      <main class="max-w-7xl mx-auto py-10 px-4">
        <slot />
      </main>

      <footer class="bg-black bg-opacity-70 py-4 mt-10 text-center text-gray-300">
        © 2026 AnunciaLocal - Todos los derechos reservados
      </footer>
    </div>
  </body>
</html>
